# Git and version control
.git
.gitignore
.gitattributes

# Python / virtualenvs / caches
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.ruff_cache/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# Secrets and environment (never in image)
.env
.env.*
!.env.example
*.pat
*.token
*.secret
*.pem
*.key
secrets.*

# Local data and logs (use volumes instead)
data/
logs/
*.sqlite
*.sqlite3
*.db
wrbot.db

# IDE / OS
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# Docker files themselves (reduce context)
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation and misc (reduce context size)
*.md
docs/
tests/
sessions/
handoff/
state/

# Keep important for runtime
!alembic/
!src/
!alembic.ini
!pyproject.toml
!uv.lock

# backups/ volume (TASK-0033) - do not ignore the mount dir in build context
!backups/
