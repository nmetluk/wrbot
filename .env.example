# Пример переменных окружения. Скопируй в .env и заполни.
# .env в .gitignore и НИКОГДА не коммитится.
# Используем UPPERCASE (конвенция для env-переменных, единообразие для деплоя).

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=

# Строка подключения к БД. Старт — SQLite (файл), позже — PostgreSQL.
# SQLite:    sqlite+aiosqlite:///./data/wrbot.sqlite3
# Postgres:  postgresql+asyncpg://user:pass@host:5432/wrbot
DATABASE_URL=sqlite+aiosqlite:///./data/wrbot.sqlite3

# Часовой пояс по умолчанию для notify_time (IANA, напр. Europe/Moscow)
DEFAULT_TIMEZONE=Europe/Moscow

# Уровень логирования: DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO

# ID приватного Telegram-канала для админ-уведомлений (M6, ADR-0008).
# Если не задан (пусто) — все отправки в админ-канал работают как no-op (без ошибок).
# Для тестов/CI/локальной разработки можно не указывать.
ADMIN_CHANNEL_ID=

# Часовой пояс для расписания дашборда (ежедневно в 21:00 по этому поясу, см. TASK-0034)
ADMIN_TZ=Europe/Moscow
