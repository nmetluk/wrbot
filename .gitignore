# ---- Секреты и окружение (НИКОГДА не коммитим) ----
# Паттерны узкие: широкие *token*/*secret* молча проглатывали легальные файлы
# (имена задач, модули вроде token_service.py) — см. SESSION-2026-06-01-03.
.env
.env.*
!.env.example
*.pat
*.token
*.secret
*.pem
*.key
secrets.json
secrets.yaml
secrets.yml
credentials*.json
.git-credentials

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ---- База данных (локальные данные не коммитим) ----
*.sqlite
*.sqlite3
*.db
data/*.sqlite*

# ---- ОС ----
.DS_Store
Thumbs.db
desktop.ini
*~

# ---- Редакторы ----
.idea/
.vscode/*
!.vscode/extensions.json
*.swp

# ---- Логи рантайма бота (не путать с sessions/ — это документация) ----
logs/
*.log

# ---- Бэкапы (дампы не коммитим, только статус в канал) ----
backups/
