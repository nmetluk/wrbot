# Кроссплатформенная нормализация. Источник правды — GitHub, исполнители
# работают на разных ОС, поэтому все текстовые файлы хранятся с LF в репозитории.
* text=auto eol=lf

# Явно текстовые форматы
*.py     text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf
*.env    text eol=lf

# Windows-скрипты должны оставаться CRLF
*.bat    text eol=crlf
*.ps1    text eol=crlf

# Бинарные форматы — не трогать
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.pdf    binary
*.sqlite binary
*.db     binary
*.ico    binary
